              </svg>
              span Facebook
      .single-construction__right
        .single-construction__right-top
          .news-card__date 13 Січень 2026
        .single-construction-slider
          <div class="home-gallery-screen__nav">
              <div class="slider-nav-button text-style-1920-button" data-gallery="prev">
                  <svg width="25" height="24" viewBox="0 0 25 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M11.8846 20L4.5 12M4.5 12L11.8846 4M4.5 12L20.5 12" stroke="#0A0F13"></path>
                  </svg>
              </div>
              <div class="home-gallery-screen__nav-digits">
                <span class="color-white" data-gallery="current">01</span>
                <span class="color-white">/</span>
                <span class="color-white" data-gallery="all">06</span>
              </div>
              <div class="slider-nav-button" data-gallery="next">
                <svg width="25" height="24" viewBox="0 0 25 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M13.1154 20L20.5 12M20.5 12L13.1154 4M20.5 12L4.5 12" stroke="#0A0F13"></path>
                </svg>
              </div>
          </div>
          .swiper-container(data-single-construction-slider)
            .swiper-wrapper
              each val in slides
                .swiper-slide
                  .single-construction-slider__image
                    .single-construction-slider__image-wrap
                      img(src=val, alt="", srcset="" loading="lazy")
        .single-construction__content
          h1 2-кімнатна квартира 65,1 м² у ЖК бізнес-класу Water Front
          h2 2-кімнатна квартира 65,1 м² у ЖК бізнес-класу Water Front
          h3 2-кімнатна квартира 65,1 м² у ЖК бізнес-класу Water Front
          h4 2-кімнатна квартира 65,1 м² у ЖК бізнес-класу Water Front
          h5 2-кімнатна квартира 65,1 м² у ЖК бізнес-класу Water Front
          h6 2-кімнатна квартира 65,1 м² у ЖК бізнес-класу Water Front
          ul 
            li 2-кімнатна квартира 65,1 м² у ЖК бізнес-класу Water Front
            li 2-кімнатна квартира 65,1 м² у ЖК бізнес-класу Water Front
          ol 
            li 2-кімнатна квартира 65,1 м² у ЖК бізнес-класу Water Front
            li 2-кімнатна квартира 65,1 м² у ЖК бізнес-класу Water Front
          <p><span style="font-weight: 700;">Встигніть придбати </span><b>2-кімнатна квартира 65,1 м² у ЖК бізнес-класу Water Front</b><b><br>
              </b><span style="font-weight: 400;"> </span><b>Готова для заселення вже цього літа!</b></p>
          <p><span style="font-weight: 400;"> </span><b>White-box комплектація:</b><b><br>
              </b><span style="font-weight: 400;">– Всі чорнові роботи виконані, залишилось лише втілити ваш дизайн!</span><span style="font-weight: 400;"><br>
              </span><span style="font-weight: 400;">– Ідеально для родини – простора кухня-вітальня, окремі кімнати, панорамні вікна.</span></p>
          <p><span style="font-weight: 400;"> </span><b>Умови акції:</b><b><br>
              </b><span style="font-weight: 400;"> </span><b>Перший внесок – $24,738</b><b><br>
              </b><span style="font-weight: 400;"> </span><b>Розтермінування на 12 місяців без здорожчання!</b><b><br>
              </b><span style="font-weight: 400;"> </span><b>Можливість заселитися одразу після купівлі</b></p>
          <p><span style="font-weight: 400;"> </span><b>ЖК Water Front – це:</b><b><br>
              </b><span style="font-weight: 400;"> </span><b>Комплекс бізнес-класу</b><span style="font-weight: 400;"> з власним </span><b>ТРЦ, спорткомплексом, басейнами, Сільпо та кінотеатром</b><b><br>
              </b><span style="font-weight: 400;"> </span><b>Закрита територія</b><span style="font-weight: 400;"> з озелененням, фонтанами та зонами відпочинку</span><span style="font-weight: 400;"><br>
              </span><span style="font-weight: 400;"> </span><b>Зручна інфраструктура</b><span style="font-weight: 400;"> – дитячі садочки, школи та магазини поруч</span></p>
          <p><span style="font-weight: 400;"> </span><b>Кількість квартир за акційною ціною обмежена!</b><b><br>
              </b><span style="font-weight: 400;">Не втрачайте можливість заселитися вже цього літа – залишайте заявку прямо зараз! </span><span style="font-weight: 400;"><br>
              </span></p>
        .single-construction-slider.single-construction-slider--no-b-padding
          .single-construction__video
            .single-construction__video-wrap
              video(controls poster="./assets/images/home/home-projects/park-avenue.jpg" playsinline)
                source(src="https://smarto.agency/wp-content/themes/smartoagency/static/smartorange_showreel1.mp4", type="video/mp4")
                <p>Ваш браузер не підтримує HTML5 відео.</p>
        .single-construction-slider
          a(href="#" type="button" data-callback-popup-call data-menu-close).button-primary.button-primary--light.button-primary--no-icon
            span Дізнатися більше у відділі продажів
  .other-news
    .other-news__content
      .other-news__title
        .color-white.text-style-1920-h-1.text-style-768-h-1.text-style-375-h-1(data-split-lines-new-animation) Останні Апдейти
      .bgtitle MORE
      .other-news__list
        each card in cards
          a(href="/single-news").news__item
            .news__item-img
              img(src=card.img alt=card.title  loading="lazy")
            .news__item-info
              .news__item-title.text-style-1920-subtitle.text-style-375-subtitle #{card.title}
              .news__item-date
                .news__item-date-digit #{card.digit}
                .news__item-date-month-year #{card.month} #{card.year}
              .news__item-arrow
                .news__item-arrow-line
                .news__item-arrow-icon
  include ../includes/contact-screen.pug
